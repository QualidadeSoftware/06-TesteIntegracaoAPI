{
	"info": {
		"_postman_id": "f1e2d3c4-b5a6-7890-1234-567890abcdef",
		"name": "EXEMPLO - Atividade Teste API",
		"description": "Coleção de REFERÊNCIA da atividade de Teste de APIs com Postman.\n\nUNISANTA - Qualidade de Software\nProf. Claudio Nunes\n\nEsta coleção é apenas um EXEMPLO conectado à API didática que sobe via Codespaces (porta 3000). Os 9 requests avaliativos cobrem GET/POST/PUT/PATCH/DELETE + cenários 404, 400 e 405. O request 00 - Resetar dados é auxiliar e existe para permitir reexecuções da coleção.\n\nUse este arquivo para conferir como organizar requests, escrever testes em pm.test() e usar variáveis {{base_url}} e {{resource_id}}. No Postman atual, ao importar esta coleção, esses testes aparecem em Scripts → Post-response.\n\nTodos os requests usam o environment `dev` por padrão. Se o topo direito mostrar No environment, selecione `dev` antes de executar.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Utilitários",
			"item": [
				{
					"name": "00 - Resetar dados",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status é 200\", function () {",
									"  pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Dados iniciais foram recriados\", function () {",
									"  const body = pm.response.json();",
									"  pm.expect(body.status).to.eql(\"reset\");",
									"  pm.expect(body.total).to.eql(5);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/reset",
							"host": ["{{base_url}}"],
							"path": ["reset"]
						}
					}
				}
			]
		},
		{
			"name": "Positivos - Caminho feliz",
			"item": [
				{
					"name": "01 - GET listar todos",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status é 200\", function () {",
									"  pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Body é um array\", function () {",
									"  const body = pm.response.json();",
									"  pm.expect(body).to.be.an(\"array\");",
									"  pm.expect(body.length).to.be.above(0);",
									"});",
									"",
									"pm.test(\"Resposta veio em menos de 2s\", function () {",
									"  pm.expect(pm.response.responseTime).to.be.below(2000);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/posts",
							"host": ["{{base_url}}"],
							"path": ["posts"]
						}
					}
				},
				{
					"name": "02 - GET buscar por ID",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status é 200\", function () {",
									"  pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"O id retornado bate com o solicitado\", function () {",
									"  const body = pm.response.json();",
									"  const expected = Number(pm.environment.get(\"resource_id\"));",
									"  pm.expect(body.id).to.eql(expected);",
									"});",
									"",
									"pm.test(\"Body tem campo title\", function () {",
									"  const body = pm.response.json();",
									"  pm.expect(body).to.have.property(\"title\");",
									"  pm.expect(body.title).to.be.a(\"string\");",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/posts/{{resource_id}}",
							"host": ["{{base_url}}"],
							"path": ["posts", "{{resource_id}}"]
						}
					}
				},
				{
					"name": "03 - POST criar recurso",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status é 201 Created\", function () {",
									"  pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test(\"Resposta inclui id gerado\", function () {",
									"  const body = pm.response.json();",
									"  pm.expect(body).to.have.property(\"id\");",
									"  pm.expect(body.id).to.be.a(\"number\");",
									"});",
									"",
									"pm.test(\"Body retorna o title que foi enviado\", function () {",
									"  const body = pm.response.json();",
									"  pm.expect(body.title).to.eql(\"teste UNISANTA\");",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"teste UNISANTA\",\n  \"body\": \"corpo do post de teste\",\n  \"userId\": 1\n}"
						},
						"url": {
							"raw": "{{base_url}}/posts",
							"host": ["{{base_url}}"],
							"path": ["posts"]
						}
					}
				},
				{
					"name": "04 - PUT substituir recurso",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status é 200\", function () {",
									"  pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Title foi atualizado\", function () {",
									"  const body = pm.response.json();",
									"  pm.expect(body.title).to.eql(\"título atualizado\");",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"título atualizado\",\n  \"body\": \"corpo atualizado\",\n  \"userId\": 1\n}"
						},
						"url": {
							"raw": "{{base_url}}/posts/{{resource_id}}",
							"host": ["{{base_url}}"],
							"path": ["posts", "{{resource_id}}"]
						}
					}
				},
				{
					"name": "05 - PATCH atualizar parcial",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status é 200\", function () {",
									"  pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Title foi atualizado parcialmente\", function () {",
									"  const body = pm.response.json();",
									"  pm.expect(body.title).to.eql(\"patch parcial\");",
									"});",
									"",
									"pm.test(\"Campos não enviados foram preservados\", function () {",
									"  const body = pm.response.json();",
									"  pm.expect(body.body).to.eql(\"corpo atualizado\");",
									"  pm.expect(body.userId).to.eql(1);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"patch parcial\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/posts/{{resource_id}}",
							"host": ["{{base_url}}"],
							"path": ["posts", "{{resource_id}}"]
						}
					}
				},
				{
					"name": "06 - DELETE remover recurso",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status é 204 No Content\", function () {",
									"  pm.response.to.have.status(204);",
									"});",
									"",
									"pm.test(\"Resposta veio em menos de 2s\", function () {",
									"  pm.expect(pm.response.responseTime).to.be.below(2000);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/posts/{{resource_id}}",
							"host": ["{{base_url}}"],
							"path": ["posts", "{{resource_id}}"]
						}
					}
				}
			]
		},
		{
			"name": "Negativos - Provocando erros",
			"item": [
				{
					"name": "07 - GET recurso inexistente (404)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status é 404 Not Found\", function () {",
									"  pm.response.to.have.status(404);",
									"});",
									"",
									"pm.test(\"Body indica o erro\", function () {",
									"  const body = pm.response.json();",
									"  pm.expect(body).to.have.property(\"error\");",
									"});",
									"",
									"pm.test(\"Tempo de resposta razoável (<2s)\", function () {",
									"  pm.expect(pm.response.responseTime).to.be.below(2000);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/posts/999999",
							"host": ["{{base_url}}"],
							"path": ["posts", "999999"]
						}
					}
				},
				{
					"name": "08 - POST body inválido (400)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status é 400 Bad Request\", function () {",
									"  pm.response.to.have.status(400);",
									"});",
									"",
									"pm.test(\"Mensagem de erro presente\", function () {",
									"  const body = pm.response.json();",
									"  pm.expect(body).to.have.property(\"message\");",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "isso não é json válido {{{"
						},
						"url": {
							"raw": "{{base_url}}/posts",
							"host": ["{{base_url}}"],
							"path": ["posts"]
						}
					}
				},
				{
					"name": "09 - DELETE em /posts (405)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status é 405 Method Not Allowed\", function () {",
									"  pm.response.to.have.status(405);",
									"});",
									"",
									"pm.test(\"Header Allow lista métodos permitidos\", function () {",
									"  pm.response.to.have.header(\"Allow\");",
									"  const allow = pm.response.headers.get(\"Allow\");",
									"  pm.expect(allow).to.include(\"GET\");",
									"  pm.expect(allow).to.include(\"POST\");",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/posts",
							"host": ["{{base_url}}"],
							"path": ["posts"]
						}
					}
				}
			]
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"if (!pm.environment.get(\"base_url\")) {",
					"  console.warn(\"Selecione o environment 'dev' no dropdown onde aparece No environment antes de rodar a coleção.\");",
					"}"
				]
			}
		}
	]
}
